# ── Secrets & environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
service-account.json
google-credentials.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.installed.cfg

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env.bak

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editors ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ───────────────────────────────────────────────────────────────────
