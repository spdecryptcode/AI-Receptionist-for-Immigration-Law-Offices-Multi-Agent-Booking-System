docker-compose.override.yml

# ── Database / migrations ────────────────────────────────────────────────────
*.sqlite3

# ── Redis ────────────────────────────────────────────────────────────────────
dump.rdb

# ── Logs ─────────────────────────────────────────────────────────────────────
