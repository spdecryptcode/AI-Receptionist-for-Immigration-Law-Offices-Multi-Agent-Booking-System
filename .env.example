# ============================================================
# IVR Immigration AI Receptionist — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
BASE_URL=https://your-domain.ngrok.io

# ---- Twilio ------------------------------------------------
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Number to cold-transfer callers to (paralegal/reception desk)
TWILIO_TRANSFER_NUMBER=+1987654321

# ---- OpenAI ------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ---- Deepgram ----------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key
# Set to true to pass mulaw 8kHz directly to Deepgram (saves 50-100ms/chunk).
# Benchmark accuracy first — see docs/VERIFICATION.md Test 3.
# Default: false (converts to linear16 16kHz first — safer)
DEEPGRAM_USE_NATIVE_MULAW=false

# ---- ElevenLabs --------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# English voice (Sofia) — default
ELEVENLABS_VOICE_ID_EN=your_english_voice_id
# Spanish voice (Sofia ES) — auto-switched on Spanish detection
ELEVENLABS_VOICE_ID_ES=your_spanish_voice_id
# Legacy single-voice fallback (used if EN/ES specific IDs not set)
ELEVENLABS_VOICE_ID=your_voice_id

# ---- GoHighLevel -------------------------------------------
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_location_id
GHL_CALENDAR_ID=your_calendar_id
# HMAC secret for validating GHL webhook signatures (required for security)
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# ---- Google Calendar ---------------------------------------
GOOGLE_CALENDAR_ID=your_calendar_id
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# ---- Redis -------------------------------------------------
# Use rediss:// (TLS) in production.
# REDIS_PASSWORD must match the value set in docker-compose.yml (requirepass).
REDIS_PASSWORD=devpassword
REDIS_URL=redis://:devpassword@localhost:6379

# ---- Supabase / PostgreSQL ---------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
DATABASE_URL=postgresql://user:pass@localhost:5432/ivr_immigration
# Key used for pgcrypto PII field encryption (passport, A-number, DOB)
# Use a vault/secrets manager in production — not plain .env
DB_ENCRYPTION_KEY=your_32_char_encryption_key_here

# ---- Office Hours & Routing --------------------------------
# 24-hour format (HH:MM). Must match OFFICE_TIMEZONE.
OFFICE_HOURS_START=09:00
OFFICE_HOURS_END=18:00
# IANA timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
OFFICE_TIMEZONE=America/New_York
# Phone number to SMS/call for urgent after-hours cases (detention, ICE)
ONCALL_ATTORNEY_PHONE=+1234567890
# Law firm name used in AI greeting and SMS messages
LAW_FIRM_NAME=Your Law Firm Name

# ---- Capacity & Resilience ---------------------------------
# Maximum simultaneous active AI calls (enforced by asyncio.Semaphore)
MAX_CONCURRENT_CALLS=10
# Silence before "Are you still there?" prompt (seconds)
SILENCE_WARNING_TIMEOUT=15
# Silence before polite goodbye + call end (seconds)
SILENCE_HARD_TIMEOUT=30

# ---- Attorney & Firm Contact --------------------------------
# SMS/voice number for emergency after-hours attorney alerts (detention, ICE)
ATTORNEY_ALERT_PHONE=+1234567890
# Direct office number — used in TwiML prompts and callback SMS
OFFICE_DIRECT_NUMBER=+1234567890

# ---- GoHighLevel Defaults ----------------------------------
# GHL user ID to assign contacts/tasks when no specific assignee is known
GHL_DEFAULT_ASSIGNEE_ID=your_ghl_user_id

# ---- Booking -----------------------------------------------
# Public Calendly/GHL/Acuity scheduling link sent via SMS after confirmation
BOOKING_URL=https://your-booking-link.com
# Soft cap: AI starts steering toward booking at this duration (minutes)
CALL_DURATION_SOFT_MINUTES=15
# Hard cap: Call ends after this duration no matter what (minutes)
CALL_DURATION_HARD_MINUTES=20

# ---- Compliance --------------------------------------------
RECORDING_CONSENT_ENABLED=true
# Days to retain full transcripts before redaction
TRANSCRIPT_RETENTION_DAYS=30
# Days to retain PII fields after client.deleted_at
DATA_RETENTION_DAYS=90

# ---- Dashboard ---------------------------------------------
# Credentials for the /dashboard/ admin UI (basic auth)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_before_deploy
